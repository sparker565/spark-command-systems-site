{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/ams-login",
      "destination": "https://ams-command-center.vercel.app"
    },
    {
      "source": "/ams-login/(.*)",
      "destination": "https://ams-command-center.vercel.app/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
